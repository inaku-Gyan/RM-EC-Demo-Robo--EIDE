# ─── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*:Zone.Identifier
desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
*.swp
*.swo
*.suo
.idea/

# VSCode — track shared project config, ignore per-user overrides
.vscode/*
!.vscode/settings.example.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ─── Build outputs ────────────────────────────────────────────────────────────
/build/

# ─── LSP / clangd ─────────────────────────────────────────────────────────────
.cache/
# .clangd is auto-generated by EIDE; it contains absolute machine-local paths — do not commit.
.clangd

# ─── STM32CubeMX ──────────────────────────────────────────────────────────────
# CubeMX can regenerate its own Makefile, which we do not actually use.
/bsp/CubeMX/Makefile
/bsp/CubeMX/build/
